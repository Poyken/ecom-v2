{
  "name": "ecommerce",
  "version": "1.0.0",
  "private": true,
  "description": "Ecommerce Multi-Tenant Platform",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api start:dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:push": "pnpm --filter api prisma db push",
    "db:studio": "pnpm --filter api prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
